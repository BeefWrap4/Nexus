# =============================================================================
# NEXUS Development Environment Configuration
# 教案部署规范: 开发环境 - SQLite + localhost
# 用法: cp .env.dev .env && docker compose up -d
# =============================================================================

# 基础配置
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-not-for-production
LOG_LEVEL=DEBUG

# 数据库 (开发环境用 SQLite, 零配置)
DATABASE_URL=sqlite+aiosqlite:///./nexus.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis (compose 中自动启动)
REDIS_URL=redis://localhost:6379/0

# ARQ Worker
ARQ_WORKER_CONCURRENCY=5
ARQ_JOB_TIMEOUT=3600
ARQ_MAX_RETRIES=3

# LLM Gateway
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-master-key

# 外部 LLM API Keys (至少配置一个)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=

# 默认 LLM 模型
DEFAULT_LLM_MODEL=deepseek-chat
DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_TIMEOUT=120
DEFAULT_LLM_MAX_TOKENS=4000
DEFAULT_LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=3
LLM_MAX_CONCURRENT_CALLS=5

# Smart Cache (RAG) — 部署在 Docker, 端口 8777
SMART_CACHE_URL=http://localhost:8777
SMART_CACHE_API_KEY=
SMART_CACHE_TIMEOUT=30
SMART_CACHE_PROJECT_ID=nexus-default

# 存储 (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nexus
S3_SECRET_KEY=nexus-secret-key
S3_BUCKET=nexus-artifacts

# Agent 配置
AGENT_MEMORY_ENABLED=true
AGENT_MEMORY_BACKEND=memory
AGENT_MEMORY_MAX_TOKENS=8000

# 可观测性
ENABLE_PROMETHEUS=true
ENABLE_OPENTELEMETRY=false

# MCP Server (开发环境默认关闭)
MCP_SERVER_ENABLED=false
MCP_SERVER_PORT=8766

# Docker Compose 变量
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus
POSTGRES_PORT=5432
MINIO_ROOT_USER=nexus
MINIO_ROOT_PASSWORD=nexus-secret-key
LITELLM_MASTER_KEY=sk-litellm-master-key
API_PORT=8765
UI_PORT=5173
