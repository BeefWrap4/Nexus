{
  "name": "nexus-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node -e \"import('node:child_process').then(({ spawnSync }) => { const env = { ...process.env, NODE_OPTIONS: '' }; for (const cmd of ['vue-tsc --noEmit', 'vite build']) { const result = spawnSync(cmd, { shell: true, stdio: 'inherit', env }); if (result.status) process.exit(result.status); } })\"",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.0",
    "@vue-flow/background": "^1.3.0",
    "@vue-flow/controls": "^1.1.0",
    "@vue-flow/core": "^1.30.0",
    "@vue-flow/minimap": "^1.4.0",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.6.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.0",
    "vue-tsc": "^3.3.3"
  }
}
