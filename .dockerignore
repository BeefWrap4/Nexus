# =============================================================================
# NEXUS Docker Ignore
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Environment files (except example)
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
log/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# Database
*.db
*.sqlite
*.sqlite3
db/*.db
db/*.sqlite

# Documentation
docs/
*.md
!README.md

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Node.js / Frontend (built separately)
nexus-ui/node_modules/
nexus-ui/dist/
nexus-ui/.cache/

# MinIO data (runtime)
minio-data/

# Prometheus / Grafana data (runtime)
prometheus-data/
grafana-data/

# Local development artifacts
*.pid
*.sock
nohup.out

# OS files
Thumbs.db
