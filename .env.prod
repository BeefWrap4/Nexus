# =============================================================================
# NEXUS Production Environment Configuration
# 教案部署规范: 生产环境 - PostgreSQL + Docker 内部网络
# 用法: cp .env.prod .env && docker compose up -d
# 注意: 生产密钥通过环境变量注入, 不写入此文件
# =============================================================================

# 基础配置
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=${NEXUS_SECRET_KEY}
LOG_LEVEL=WARNING

# 数据库 (生产环境使用 PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://nexus:${POSTGRES_PASSWORD}@postgres:5432/nexus
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis (compose 内部网络)
REDIS_URL=redis://redis:6379/0

# ARQ Worker
ARQ_WORKER_CONCURRENCY=20
ARQ_JOB_TIMEOUT=3600
ARQ_MAX_RETRIES=3

# LLM Gateway
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_API_KEY=${LITELLM_MASTER_KEY}

# 外部 LLM API Keys (通过环境变量注入, 不写入文件)
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
DASHSCOPE_API_KEY=${DASHSCOPE_API_KEY}
SILICONFLOW_API_KEY=${SILICONFLOW_API_KEY}

# 默认 LLM 模型
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_TIMEOUT=120
DEFAULT_LLM_MAX_TOKENS=4000
DEFAULT_LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=3
LLM_MAX_CONCURRENT_CALLS=20

# Smart Cache (RAG) — Docker 内部网络
SMART_CACHE_URL=http://smart-cache:8777
SMART_CACHE_API_KEY=${SMART_CACHE_API_KEY}
SMART_CACHE_TIMEOUT=30
SMART_CACHE_PROJECT_ID=nexus-production

# 存储 (MinIO)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
S3_BUCKET=nexus-artifacts

# Agent 配置
AGENT_MEMORY_ENABLED=true
AGENT_MEMORY_BACKEND=redis
AGENT_MEMORY_MAX_TOKENS=8000

# 可观测性
ENABLE_PROMETHEUS=true
ENABLE_OPENTELEMETRY=false

# MCP Server (生产按需开启)
MCP_SERVER_ENABLED=false
MCP_SERVER_PORT=8766

# Docker Compose 变量 (敏感值通过环境变量注入)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=nexus
POSTGRES_PORT=5432
MINIO_ROOT_USER=nexus
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}
LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY}
DOCKER_BUILD_TARGET=production
API_PORT=8000
UI_PORT=80
