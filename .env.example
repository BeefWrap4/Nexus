# NEXUS 环境变量配置

# 基础配置
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# 数据库（开发用 SQLite，生产用 PostgreSQL）
# DATABASE_URL=sqlite+aiosqlite:///./nexus.db
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# Redis
REDIS_URL=redis://localhost:6379/0

# ARQ Worker
ARQ_WORKER_CONCURRENCY=10
ARQ_JOB_TIMEOUT=3600
ARQ_MAX_RETRIES=3

# LLM Gateway
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-master-key

# 外部LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
DASHSCOPE_API_KEY=sk-...
SILICONFLOW_API_KEY=sk-...

# Smart Cache (RAG) — llm-cache-engine 部署在 Docker，端口 8777
SMART_CACHE_URL=http://localhost:8777
SMART_CACHE_API_KEY=
SMART_CACHE_TIMEOUT=30
SMART_CACHE_PROJECT_ID=nexus-default

# 存储
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nexus
S3_SECRET_KEY=nexus-secret-key
S3_BUCKET=nexus-artifacts
