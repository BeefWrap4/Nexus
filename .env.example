# ============================================================================
# ⚠️  安全警告 / SECURITY WARNING
# ============================================================================
#
# 本文件仅作为环境变量模板,不包含真实凭证。
# This file is a TEMPLATE only. DO NOT commit real credentials.
#
# 使用前必须:
# 1. 复制为 .env:  cp .env.example .env
# 2. 替换所有 <REPLACE_...> 占位符为真实值
# 3. 确保 .env 已在 .gitignore 中(不会被提交到版本控制)
#
# 生产环境必须使用强随机字符串作为密钥,建议:
# - SECRET_KEY: 至少64字符的随机字符串
# - 密码: 至少16字符,包含大小写字母、数字、特殊字符
# - API Keys: 从对应服务商获取真实密钥
#
# 运行验证脚本检查配置安全性:
#   python scripts/validate_security.py
#
# ============================================================================

# NEXUS 环境变量配置

# 基础配置
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=<REPLACE_WITH_STRONG_RANDOM_STRING_MIN_64_CHARS>

# JWT专用配置（密钥分离与轮换机制）
# JWT_SECRET_KEY: 用于签名和验证JWT Token的密钥（至少32字符）
JWT_SECRET_KEY=<REPLACE_WITH_STRONG_RANDOM_STRING_MIN_32_CHARS>
# JWT_ALGORITHM: JWT签名算法（默认HS256）
JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES: Access Token过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# JWT_REFRESH_TOKEN_EXPIRE_DAYS: Refresh Token过期时间（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT_PREVIOUS_SECRET_KEYS: 历史密钥列表（逗号分隔，用于验证旧Token）
# 示例: JWT_PREVIOUS_SECRET_KEYS=old_key_1,old_key_2
JWT_PREVIOUS_SECRET_KEYS=

# 开发环境 API Key 回退(仅非 production 环境生效)
# 设置后 X-API-Key header 匹配时直接通过认证,不查数据库
# 生产环境必须留空,否则启动安全校验会报错
DEV_API_KEY=<LEAVE_BLANK_FOR_PRODUCTION_OR_SET_FOR_DEV_TESTING>

# 数据库(开发用 SQLite,生产用 PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:///./nexus.db
# ⚠️  生产环境: 必须用 nexus_app 角色 (NOSUPERUSER NOBYPASSRLS) — 不用 nexus superuser。
#     RLS migration (add_row_level_security.py) 创建了 nexus_app, superuser 连接会
#     隐式 BYPASSRLS, 让 FORCE ROW LEVEL SECURITY 失效。
#     app 启动守卫 (main.py::_verify_db_role_not_superuser) 会校验这一点, production
#     环境发现 superuser 会直接 FATAL 退出。
# 密码: 由 NEXUS_APP_DB_PASSWORD 控制, 必须与 migration 时设置的值一致。
NEXUS_APP_DB_PASSWORD=nexus_app_password
DATABASE_URL=postgresql+asyncpg://nexus_app:${NEXUS_APP_DB_PASSWORD}@localhost:5432/nexus
# 首次部署时, alembic 需要 superuser 创建 nexus_app 角色 (CREATE ROLE 需要 CREATEROLE)。
# 部署脚本会自动用 superuser 跑一次 migration, 后续可清空。
# MIGRATION_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/nexus

# Redis
REDIS_URL=redis://localhost:6379/0

# ARQ Worker
ARQ_WORKER_CONCURRENCY=10
ARQ_JOB_TIMEOUT=3600
ARQ_MAX_RETRIES=3

# LLM Gateway
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=<REPLACE_WITH_STRONG_RANDOM_STRING>

# 外部LLM API Keys
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
DEEPSEEK_API_KEY=<YOUR_DEEPSEEK_API_KEY>
DASHSCOPE_API_KEY=<YOUR_DASHSCOPE_API_KEY>
SILICONFLOW_API_KEY=<YOUR_SILICONFLOW_API_KEY>

# Smart Cache (RAG) — llm-cache-engine 部署在 Docker，端口 8777
SMART_CACHE_URL=http://localhost:8777
SMART_CACHE_API_KEY=
SMART_CACHE_TIMEOUT=30
SMART_CACHE_PROJECT_ID=nexus-default

# 存储
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
S3_BUCKET=nexus-artifacts

# ============================================================================
# 附加: PostgreSQL & MinIO 配置(用于 Docker Compose)
# 这些变量通常在 docker-compose.yml 或单独的 .env 文件中定义
# ============================================================================
# POSTGRES_USER=<REPLACE_WITH_USERNAME>
# POSTGRES_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>
# MINIO_ROOT_USER=<REPLACE_WITH_USERNAME>
# MINIO_ROOT_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>

# =============================================================================
# PostgreSQL Replication Configuration
# =============================================================================
POSTGRES_USER=nexus
POSTGRES_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>
POSTGRES_DB=nexus
POSTGRES_PORT=5433
POSTGRES_REPLICA_PORT=5434

# Replication User Password
REPLICATION_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>

# =============================================================================
# Redis Sentinel Configuration
# =============================================================================
REDIS_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>
REDIS_MASTER_PORT=6380
REDIS_REPLICA1_PORT=6381
REDIS_REPLICA2_PORT=6382
SENTINEL1_PORT=26379
SENTINEL2_PORT=26380
SENTINEL3_PORT=26381

# Application Redis Connection (use sentinel)
REDIS_SENTINEL_HOSTS=nexus-redis-sentinel-1:26379,nexus-redis-sentinel-2:26380,nexus-redis-sentinel-3:26381
REDIS_SENTINEL_MASTER=mymaster
